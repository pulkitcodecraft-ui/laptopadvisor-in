{
  "name": "engineering-laptop-advisor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "next build && firebase deploy",
    "deploy:hosting": "next build && firebase deploy --only hosting",
    "firebase:emulators": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "firebase:seed": "node --env-file=.env.local scripts/seed-firestore.mjs",
    "firebase:audit": "node --env-file=.env.local scripts/security-audit.mjs",
    "firebase:deploy-rules": "firebase deploy --only firestore:rules,storage"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.23",
    "firebase": "^12.15.0",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "firebase-admin": "^13.0.2",
    "firebase-tools": "^14.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
