rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /laptops/{laptopId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
        (firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) ||
         request.auth.token.admin == true);
    }
  }
}
